# Copier ce fichier en « .env » (sans extension) et y mettre les vraies valeurs.
# Le fichier .env est ignoré par git : les secrets ne sont jamais partagés.

# Token Pipedrive (Paramètres > Préférences personnelles > API)
PIPEDRIVE_TOKEN=

# (Optionnel) URL de webhook entrant Slack ou Teams pour recevoir le récapitulatif.
# Laisser vide ou supprimer la ligne si non utilisé.
# NOTIF_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
